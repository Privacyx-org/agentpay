{
  "name": "railent-sdk",
  "version": "0.1.1",
  "description": "Railent SDK - payment rails for autonomous agents",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/abi"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "e2e": "tsx examples/e2e.ts"
  },
  "keywords": [
    "web3",
    "ai",
    "agents",
    "escrow",
    "railent"
  ],
  "license": "MIT",
  "dependencies": {
    "ethers": "^6.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
